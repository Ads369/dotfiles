// cSpell Settings
{
  // Version of the setting file.  Always 0.2
  "version": "0.2",
  // language - current active spelling language
  "language": "en,ru",
  // words - list of words to be always considered correct
  "words": [],
  // flagWords - list of words to be always considered incorrect
  // This is useful for offensive words and common spelling errors.
  // For example "hte" should be "the"
  // "flagWords": ["hte"],

  // Enable your dictionary by adding it to the list of `dictionaries`
  "dictionaries": ["python_custom", "lua_custom"],

  "overrides": [
    {
      "filename": "*.lua",
      "dictionaries": ["lua_custom"]
    },
    {
      "filename": "*.py",
      "dictionaries": ["python_custom"]
    }
  ],

  // Tell CSpell about your dictionary
  "dictionaryDefinitions": [
    {
      "name": "lua_custom",
      "path": "~/.dotfiles/nvim/cspell_dict/lua.txt",
      "addWords": true
    },
    {
      "name": "python_custom",
      "path": "~/.dotfiles/nvim/cspell_dict/python.txt",
      "addWords": true
    }
  ]
}
